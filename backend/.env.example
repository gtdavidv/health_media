PORT=3001
NODE_ENV=development

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:password@localhost:5432/health_media

# OpenAI
OPENAI_KEY=your-openai-api-key

# Admin
ADMIN_PASSWORD=your-admin-password
SESSION_SECRET=a-long-random-string-change-this

# Frontend URL — used for CORS and sitemap generation
FRONTEND_URL=http://localhost:3000

# S3 media bucket (populated from Terraform outputs)
MEDIA_BUCKET=your-media-bucket-name
MEDIA_CDN_DOMAIN=your-cloudfront-domain.cloudfront.net